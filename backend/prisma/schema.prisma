generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())

  owned          OwnedPlayer[]
  squads         FantasySquad[]
  squadHistory   FantasySquadHistory[]
  memberships    LeagueMembership[]
  ownedLeagues   League[]
  scores         UserGameweekScore[]
  tradesSent     TradeOffer[]        @relation("TradeFrom")
  tradesReceived TradeOffer[]        @relation("TradeTo")
  listings       PlayerListing[]
}

// Competencia real de FotMob: liga doméstica (LaLiga, Liga MX…), copa o el Mundial.
// Es lo que el usuario elige al crear su liga privada de fantasy.
model Competition {
  id        Int      @id @default(autoincrement())
  fotmobId  Int      @unique
  name      String
  ccode     String? // país (ESP, MEX, ENG) o INT para internacionales
  type      String   @default("league") // league | cup
  logoUrl   String?
  priority  Int      @default(100) // orden en el selector (menor = arriba)
  isCurrent Boolean  @default(false) // "en temporada ahora" (Mundial mientras dure)
  season    String?
  createdAt DateTime @default(now())

  teams     Team[]
  players   Player[]
  matches   Match[]
  gameweeks Gameweek[]
  leagues   League[]
}

// Equipo dentro de una competencia: club (Real Madrid) o selección (México).
model Team {
  id            Int         @id @default(autoincrement())
  competitionId Int
  fotmobId      Int
  name          String
  logoUrl       String?
  flag          String? // emoji de bandera solo para selecciones
  group         String? // grupo (fase de grupos del Mundial)
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  players     Player[]
  homeMatches Match[]  @relation("HomeMatches")
  awayMatches Match[]  @relation("AwayMatches")

  @@unique([competitionId, fotmobId])
}

model Player {
  id            Int         @id @default(autoincrement())
  competitionId Int
  teamId        Int
  fotmobId      Int
  name          String
  position      String // POR | DEF | MED | DEL
  rating        Int
  basePrice     Int
  photoUrl      String?
  age           Int?
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  team          Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)

  owned    OwnedPlayer[]
  stats    PlayerGameweekStats[]
  listings PlayerListing[]

  @@unique([competitionId, fotmobId])
  @@index([competitionId])
  @@index([teamId])
}

// Liga privada de fantasy (creada por un usuario), atada a UNA competencia real.
model League {
  id            String      @id @default(cuid())
  name          String
  inviteCode    String      @unique
  ownerId       String
  competitionId Int
  createdAt     DateTime    @default(now())
  owner         User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  competition   Competition @relation(fields: [competitionId], references: [id])

  members      LeagueMembership[]
  ownedPlayers OwnedPlayer[]
  squads       FantasySquad[]
  squadHistory FantasySquadHistory[]
  scores       UserGameweekScore[]
  trades       TradeOffer[]
  listings     PlayerListing[]

  @@index([competitionId])
}

// El presupuesto vive AQUÍ, no en User: cada liga tiene su propia economía
// cerrada (empiezas con €50M en cada liga y el dinero no cruza entre ligas).
model LeagueMembership {
  id       String   @id @default(cuid())
  userId   String
  leagueId String
  coins    Int      @default(50000000) // presupuesto en € dentro de ESTA liga (STARTING_COINS)
  joinedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  league   League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([userId, leagueId])
}

// Exclusividad por liga: un jugador solo puede tener UN dueño dentro de cada liga.
model OwnedPlayer {
  id              String    @id @default(cuid())
  userId          String
  leagueId        String
  playerId        Int
  acquiredAt      DateTime  @default(now())
  clause          Int       @default(0) // precio de clausulazo (subible por el dueño)
  protectedUntil  DateTime? // no se puede clausular antes de esta fecha
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  league          League    @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  player          Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([leagueId, playerId])
  @@index([userId, leagueId])
}

// Venta abierta: el dueño pone su carta en el mercado a un precio fijo.
model PlayerListing {
  id        String   @id @default(cuid())
  leagueId  String
  sellerId  String
  playerId  Int
  price     Int
  createdAt DateTime @default(now())
  league    League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  seller    User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([leagueId, playerId])
  @@index([leagueId])
}

model FantasySquad {
  id        String @id @default(cuid())
  userId    String
  leagueId  String
  formation String @default("4-4-2")
  playerIds String @default("") // ids separados por coma, en orden de slot
  captainId Int?
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  league    League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([userId, leagueId])
}

// Una fila por cada vez que se guarda un once (a diferencia de FantasySquad,
// que solo tiene la versión actual). Sirve para saber, jornada por jornada,
// qué alineación estaba vigente al momento del deadline de esa jornada: si
// se edita mientras la jornada ya está en juego, ese cambio queda en el
// historial pero no puede "viajar al pasado" a puntuar una jornada que ya
// arrancó (ver recomputeScores en services/sync.ts).
model FantasySquadHistory {
  id        String   @id @default(cuid())
  userId    String
  leagueId  String
  formation String
  playerIds String // ids separados por coma, en orden de slot
  captainId Int?
  savedAt   DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  league    League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@index([userId, leagueId, savedAt])
}

model TradeOffer {
  id                String   @id @default(cuid())
  leagueId          String
  fromUserId        String
  toUserId          String
  offeredPlayerId   Int
  requestedPlayerId Int
  coins             Int      @default(0)
  status            String   @default("pending") // pending | accepted | rejected
  createdAt         DateTime @default(now())
  league            League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  fromUser          User     @relation("TradeFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser            User     @relation("TradeTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([leagueId])
  @@index([toUserId, status])
}

// Jornada de una competencia (matchday de liga, o ronda del Mundial).
model Gameweek {
  id            Int         @id @default(autoincrement())
  competitionId Int
  number        Int
  deadline      DateTime
  status        String      @default("upcoming")
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  stats  PlayerGameweekStats[]
  scores UserGameweekScore[]

  @@unique([competitionId, number])
}

model PlayerGameweekStats {
  id         String   @id @default(cuid())
  playerId   Int
  gameweekId Int
  goals      Int      @default(0)
  assists    Int      @default(0)
  points     Int      @default(0)
  player     Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  gameweek   Gameweek @relation(fields: [gameweekId], references: [id], onDelete: Cascade)

  @@unique([playerId, gameweekId])
}

model UserGameweekScore {
  id         String   @id @default(cuid())
  userId     String
  leagueId   String
  gameweekId Int
  points     Int      @default(0)
  paidOut    Boolean  @default(false) // premio en € ya abonado al cerrar la jornada
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  league     League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  gameweek   Gameweek @relation(fields: [gameweekId], references: [id], onDelete: Cascade)

  @@unique([userId, leagueId, gameweekId])
}

// Fixture real de una competencia (fuente FotMob).
model Match {
  id              Int         @id @default(autoincrement())
  competitionId   Int
  fotmobId        Int         @unique
  homeTeamId      Int?
  awayTeamId      Int?
  homeName        String
  awayName        String
  group           String?
  round           Int? // matchday de liga o ronda del Mundial
  utcTime         DateTime?
  status          String      @default("scheduled") // scheduled | live | finished
  homeScore       Int?
  awayScore       Int?
  detailsSyncedAt DateTime?
  competition     Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  homeTeam        Team?       @relation("HomeMatches", fields: [homeTeamId], references: [id])
  awayTeam        Team?       @relation("AwayMatches", fields: [awayTeamId], references: [id])

  @@index([competitionId, status])
  @@index([competitionId, round])
}
