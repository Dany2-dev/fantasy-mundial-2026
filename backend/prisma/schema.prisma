generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  coins     Int      @default(15000)
  createdAt DateTime @default(now())

  owned          OwnedPlayer[]
  squads         FantasySquad[]
  memberships    LeagueMembership[]
  ownedLeagues   League[]
  scores         UserGameweekScore[]
  tradesSent     TradeOffer[]        @relation("TradeFrom")
  tradesReceived TradeOffer[]        @relation("TradeTo")
  listings       PlayerListing[]
  
  coinTransactions CoinTransaction[]
  paymentOrders    PaymentOrder[]
  faucetLimits     FaucetLimit[]
}

// Competencia real de FotMob: liga doméstica (LaLiga, Liga MX…), copa o el Mundial.
// Es lo que el usuario elige al crear su liga privada de fantasy.
model Competition {
  id        Int      @id @default(autoincrement())
  fotmobId  Int      @unique
  name      String
  ccode     String? // país (ESP, MEX, ENG) o INT para internacionales
  type      String   @default("league") // league | cup
  logoUrl   String?
  priority  Int      @default(100) // orden en el selector (menor = arriba)
  isCurrent Boolean  @default(false) // "en temporada ahora" (Mundial mientras dure)
  season    String?
  createdAt DateTime @default(now())

  teams     Team[]
  players   Player[]
  matches   Match[]
  gameweeks Gameweek[]
  leagues   League[]
}

// Equipo dentro de una competencia: club (Real Madrid) o selección (México).
model Team {
  id            Int         @id @default(autoincrement())
  competitionId Int
  fotmobId      Int
  name          String
  logoUrl       String?
  flag          String? // emoji de bandera solo para selecciones
  group         String? // grupo (fase de grupos del Mundial)
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  players     Player[]
  homeMatches Match[]  @relation("HomeMatches")
  awayMatches Match[]  @relation("AwayMatches")

  @@unique([competitionId, fotmobId])
}

model Player {
  id            Int         @id @default(autoincrement())
  competitionId Int
  teamId        Int
  fotmobId      Int
  name          String
  position      String // POR | DEF | MED | DEL
  rating        Int
  basePrice     Int
  photoUrl      String?
  age           Int?
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  team          Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)

  owned    OwnedPlayer[]
  stats    PlayerGameweekStats[]
  listings PlayerListing[]

  @@unique([competitionId, fotmobId])
  @@index([competitionId])
  @@index([teamId])
}

// Liga privada de fantasy (creada por un usuario), atada a UNA competencia real.
model League {
  id            String      @id @default(cuid())
  name          String
  inviteCode    String      @unique
  ownerId       String
  competitionId Int
  createdAt     DateTime    @default(now())
  owner         User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  competition   Competition @relation(fields: [competitionId], references: [id])

  members      LeagueMembership[]
  ownedPlayers OwnedPlayer[]
  squads       FantasySquad[]
  scores       UserGameweekScore[]
  trades       TradeOffer[]
  listings     PlayerListing[]

  @@index([competitionId])
}

model LeagueMembership {
  id       String   @id @default(cuid())
  userId   String
  leagueId String
  joinedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  league   League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([userId, leagueId])
}

// Exclusividad por liga: un jugador solo puede tener UN dueño dentro de cada liga.
model OwnedPlayer {
  id              String    @id @default(cuid())
  userId          String
  leagueId        String
  playerId        Int
  acquiredAt      DateTime  @default(now())
  clause          Int       @default(0) // precio de clausulazo (subible por el dueño)
  protectedUntil  DateTime? // no se puede clausular antes de esta fecha
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  league          League    @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  player          Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([leagueId, playerId])
  @@index([userId, leagueId])
}

// Venta abierta: el dueño pone su carta en el mercado a un precio fijo.
model PlayerListing {
  id        String   @id @default(cuid())
  leagueId  String
  sellerId  String
  playerId  Int
  price     Int
  createdAt DateTime @default(now())
  league    League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  seller    User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([leagueId, playerId])
  @@index([leagueId])
}

model FantasySquad {
  id        String @id @default(cuid())
  userId    String
  leagueId  String
  formation String @default("4-4-2")
  playerIds String @default("") // ids separados por coma, en orden de slot
  captainId Int?
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  league    League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([userId, leagueId])
}

model TradeOffer {
  id                String   @id @default(cuid())
  leagueId          String
  fromUserId        String
  toUserId          String
  offeredPlayerId   Int
  requestedPlayerId Int
  coins             Int      @default(0)
  status            String   @default("pending") // pending | accepted | rejected
  createdAt         DateTime @default(now())
  league            League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  fromUser          User     @relation("TradeFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser            User     @relation("TradeTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([leagueId])
  @@index([toUserId, status])
}

// Jornada de una competencia (matchday de liga, o ronda del Mundial).
model Gameweek {
  id            Int         @id @default(autoincrement())
  competitionId Int
  number        Int
  deadline      DateTime
  status        String      @default("upcoming")
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  stats  PlayerGameweekStats[]
  scores UserGameweekScore[]

  @@unique([competitionId, number])
}

model PlayerGameweekStats {
  id         String   @id @default(cuid())
  playerId   Int
  gameweekId Int
  goals      Int      @default(0)
  assists    Int      @default(0)
  points     Int      @default(0)
  player     Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  gameweek   Gameweek @relation(fields: [gameweekId], references: [id], onDelete: Cascade)

  @@unique([playerId, gameweekId])
}

model UserGameweekScore {
  id         String   @id @default(cuid())
  userId     String
  leagueId   String
  gameweekId Int
  points     Int      @default(0)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  league     League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  gameweek   Gameweek @relation(fields: [gameweekId], references: [id], onDelete: Cascade)

  @@unique([userId, leagueId, gameweekId])
}

// Fixture real de una competencia (fuente FotMob).
model Match {
  id              Int         @id @default(autoincrement())
  competitionId   Int
  fotmobId        Int         @unique
  homeTeamId      Int?
  awayTeamId      Int?
  homeName        String
  awayName        String
  group           String?
  round           Int? // matchday de liga o ronda del Mundial
  utcTime         DateTime?
  status          String      @default("scheduled") // scheduled | live | finished
  homeScore       Int?
  awayScore       Int?
  detailsSyncedAt DateTime?
  competition     Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  homeTeam        Team?       @relation("HomeMatches", fields: [homeTeamId], references: [id])
  awayTeam        Team?       @relation("AwayMatches", fields: [awayTeamId], references: [id])

  @@index([competitionId, status])
  @@index([competitionId, round])
}

model SystemAccount {
  id               String            @id // ej. "SYSTEM_EMISSION", "SYSTEM_TAX", "SYSTEM_SINK"
  balance          Int               @default(0)
  updatedAt        DateTime          @updatedAt
  
  coinTransactions CoinTransaction[]
}

model CoinTransaction {
  id              String              @id @default(cuid())
  userId          String?             // Nullable por GDPR o baneo
  systemAccountId String?             // Nullable si es transferencia directa entre usuarios
  amount          Int
  type            CoinTransactionType
  referenceId     String?             // Clave de idempotencia o entidad relacionada (ej. 'daily-login-YYYY-MM-DD')
  status          TransactionStatus   @default(COMPLETED)
  description     String?
  createdAt       DateTime            @default(now())

  user            User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  systemAccount   SystemAccount?      @relation(fields: [systemAccountId], references: [id])

  @@index([userId])
  @@index([systemAccountId])
  @@index([referenceId])
  @@index([createdAt])
}

model FaucetLimit {
  id         String   @id @default(cuid())
  userId     String?  // Nullable por GDPR
  periodKey  String   // Formato: "YYYY-Www" (ej. "2026-W28")
  amount     Int      @default(0) // Acumulado semanal global
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([userId, periodKey])
}

model LeagueStats {
  id                             String   @id @default(cuid())
  leagueId                       String
  gameweekId                     Int
  giniIndex                      Float
  top25PercentileCoinsThreshold  Int
  bottom25PercentileCoinsThreshold Int
  calculatedAt                   DateTime @default(now())

  @@unique([leagueId, gameweekId])
}

model PaymentOrder {
  id               String        @id @default(cuid())
  userId           String?
  stripeSessionId  String        @unique
  amountPaidCents  Int
  currency         String        @default("usd")
  coinsAmount      Int
  status           PaymentStatus @default(PENDING)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user             User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([stripeSessionId])
}

model RefundJob {
  id               String        @id @default(cuid())
  stripeSessionId  String        @unique
  paymentIntentId  String?
  amountPaidCents  Int
  attempts         Int           @default(0)
  status           RefundStatus  @default(PENDING)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

enum RefundStatus {
  PENDING
  PROCESSING
  COMPLETED
  NEEDS_MANUAL_REVIEW
  FAILED
}

enum CoinTransactionType {
  BUY
  TRANSFER
  REWARD
  PACK_PURCHASE
  QUICK_SELL
  MARKET_TAX
  CLAUSE_BUY
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}
